import java.io.*;
import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();
        
        String arr[] = s.split(" ");
        
        String longest = "";
        for (String word : arr) {
            if (word.length() > longest.length()) {
                longest = word;
            }
        }
        
        System.out.println(longest);
    }
}
